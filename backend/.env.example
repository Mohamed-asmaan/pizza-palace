MONGO_URI=mongodb://localhost:27017/pizza-palace
JWT_SECRET=your_jwt_secret_key_change_in_production
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173,https://pizza-palace-gules.vercel.app

# Optional: create admin account when catalog is first imported
# ADMIN_EMAIL=you@example.com
# ADMIN_PASSWORD=your_secure_password
# ADMIN_NAME=Your Name

# Razorpay TEST keys only (https://dashboard.razorpay.com/app/keys → Generate Test Key)
# Must start with rzp_test_ — live keys (rzp_live_*) are blocked
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_test_key_secret